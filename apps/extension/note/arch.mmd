%% apps/extension 架构简图（Mermaid）
%% 可在支持 Mermaid 的编辑器或 VS Code 插件中预览

flowchart TB
    subgraph Build[Build Vite]
        Vite[vite.config.ts]
        Entries[多入口HTML]
        Dist[dist输出]
        Vite --> Entries
        Vite --> Dist
    end

    subgraph Chrome[Chrome扩展MV3]
        Manifest[manifest.json]
    end

    Dist --> Manifest

    subgraph PageEntry[页面入口]
        Popup[popup.html]
        Side[sidepanel.html]
        Opt[options.html]
        Main[main.tsx]
        Popup --> Main
        Side --> Main
        Opt --> Main
    end

    Manifest -.-> Main

    subgraph UI[界面交互]
        App[App.tsx]
        Main --> App
    end

    subgraph Data[数据同步]
        Hook[usePromptData]
        Store[store.ts]
        App --> Hook
        App -.-> Store
    end

    subgraph Local[本地持久化]
        Storage[storage.ts]
        Mock[mockData.ts]
        Hook --> Storage
        Hook --> Mock
    end

    subgraph Remote[远端Supabase]
        SB[supabase.ts]
        RT[runtime.ts]
        Hook --> SB
        App --> SB
        SB --> RT
    end

    subgraph Ext[外围模块]
        Types[types.ts]
        BrowserUtil[browser.ts]
        ManifestTs[manifest.ts]
        SB --- Types
        Storage --- Types
        Hook --- Types
        App --- Types
    end

    subgraph Cloud[Supabase云端]
        Auth[Auth会话]
        DB[(数据库表)]
        Fn[EdgeFunction]
        SB --> Auth
        SB --> DB
        SB --> Fn
    end

    Vite -.-> Manifest
