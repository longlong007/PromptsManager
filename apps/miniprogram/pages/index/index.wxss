.user-bar {
  margin-bottom: 24rpx;
}

.logout-link {
  color: #dc2626;
  font-size: 26rpx;
}

.section-title {
  font-size: 40rpx;
  font-weight: 700;
  margin-bottom: 24rpx;
}

.link {
  color: #2563eb;
  font-size: 26rpx;
}

.empty-inner {
  padding: 40rpx 0;
  text-align: center;
}

.recent-item {
  padding: 24rpx;
  border: 2rpx solid #e5e7eb;
  border-radius: 16rpx;
  margin-top: 16rpx;
}

.recent-title {
  font-weight: 600;
  font-size: 30rpx;
  display: block;
}

.recent-content {
  font-size: 26rpx;
  color: #6b7280;
  margin-top: 8rpx;
  display: block;
}

.action-btn {
  width: 100%;
  margin-top: 16rpx;
}

.history-item {
  display: flex;
  justify-content: space-between;
  padding: 16rpx 0;
  border-bottom: 2rpx solid #f3f4f6;
  font-size: 26rpx;
}

.history-item:last-child {
  border-bottom: none;
}
