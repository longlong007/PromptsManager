<view class="container">
  <view class="search-bar">
    <input
      class="input search-input"
      placeholder="搜索标题、内容、标签..."
      value="{{searchQuery}}"
      bindinput="onSearchInput"
      confirm-type="search"
      bindconfirm="onSearch"
    />
    <picker
      mode="selector"
      range="{{categoryNames}}"
      value="{{categoryIndex}}"
      bindchange="onCategoryChange"
    >
      <view class="picker-btn picker-wrap">{{categoryNames[categoryIndex]}}</view>
    </picker>
    <button class="btn-primary search-btn" size="mini" bindtap="onSearch">搜索</button>
  </view>

  <view class="toolbar flex-between">
    <view class="flex-row">
      <button
        wx:if="{{!batchMode}}"
        class="btn-secondary toolbar-btn"
        size="mini"
        bindtap="onToggleBatch"
      >
        批量
      </button>
      <block wx:else>
        <button class="btn-danger toolbar-btn" size="mini" bindtap="onBatchDelete">
          删除({{selectedIds.length}})
        </button>
        <button class="btn-secondary toolbar-btn" size="mini" bindtap="onBatchCopy">
          复制
        </button>
        <button class="btn-secondary toolbar-btn" size="mini" bindtap="onToggleBatch">
          取消
        </button>
      </block>
    </view>
    <button class="btn-primary toolbar-btn" size="mini" bindtap="goNew">+ 新建</button>
  </view>

  <view wx:if="{{loading}}" class="empty">加载中...</view>
  <view wx:elif="{{displayPrompts.length === 0}}" class="empty">
    <text>{{prompts.length === 0 ? '还没有任何 Prompt' : '没有匹配的 Prompt'}}</text>
    <button wx:if="{{prompts.length === 0}}" class="btn-primary empty-btn" bindtap="goNew">
      创建第一个
    </button>
  </view>

  <view wx:else class="prompt-list">
    <view
      wx:for="{{displayPrompts}}"
      wx:key="id"
      class="prompt-card"
    >
      <view class="prompt-card-inner flex-row">
        <checkbox
          wx:if="{{batchMode}}"
          class="prompt-checkbox"
          checked="{{item.selected}}"
          data-id="{{item.id}}"
          bindtap="onToggleSelect"
        />
        <view class="prompt-body flex-1" data-id="{{item.id}}" bindtap="onCardTap">
          <view class="prompt-title ellipsis-1">{{item.title}}</view>
          <view class="prompt-content ellipsis-2">{{item.content}}</view>
          <view wx:if="{{item.tags.length > 0}}" class="tag-row ellipsis-1">
            <text
              wx:for="{{item.tags}}"
              wx:for-item="tag"
              wx:key="*this"
              wx:if="{{index < 3}}"
              class="tag"
            >{{tag}}</text>
            <text wx:if="{{item.tags.length > 3}}" class="tag tag-more">+{{item.tags.length - 3}}</text>
          </view>
          <view class="meta ellipsis-1">
            <text>{{item.categoryLabel}}</text>
            <text class="meta-dot">·</text>
            <text>使用 {{item.usage_count}} 次</text>
            <text class="meta-dot">·</text>
            <text>{{item.dateLabel}}</text>
          </view>
        </view>
      </view>
      <view wx:if="{{!batchMode}}" class="prompt-actions">
        <text
          class="action-btn"
          data-id="{{item.id}}"
          data-content="{{item.content}}"
          data-title="{{item.title}}"
          data-usage="{{item.usage_count}}"
          catchtap="onCopy"
        >复制</text>
        <text class="action-btn" data-id="{{item.id}}" catchtap="goEdit">编辑</text>
        <text class="action-btn danger" data-id="{{item.id}}" catchtap="onDelete">删除</text>
      </view>
    </view>
  </view>
</view>
