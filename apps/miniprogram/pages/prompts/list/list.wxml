<view class="container">
  <view class="search-bar">
    <input
      class="input search-input"
      placeholder="搜索标题、内容、标签..."
      value="{{searchQuery}}"
      bindinput="onSearchInput"
      confirm-type="search"
      bindconfirm="onSearch"
    />
    <picker
      mode="selector"
      range="{{categoryNames}}"
      value="{{categoryIndex}}"
      bindchange="onCategoryChange"
    >
      <view class="picker-btn">{{categoryNames[categoryIndex]}}</view>
    </picker>
    <button class="btn-primary search-btn" size="mini" bindtap="onSearch">搜索</button>
  </view>

  <view class="toolbar flex-between">
    <view class="flex-row">
      <button
        wx:if="{{!batchMode}}"
        class="btn-secondary toolbar-btn"
        size="mini"
        bindtap="onToggleBatch"
      >
        批量
      </button>
      <block wx:else>
        <button class="btn-danger toolbar-btn" size="mini" bindtap="onBatchDelete">
          删除({{selectedIds.length}})
        </button>
        <button class="btn-secondary toolbar-btn" size="mini" bindtap="onBatchCopy">
          复制
        </button>
        <button class="btn-secondary toolbar-btn" size="mini" bindtap="onToggleBatch">
          取消
        </button>
      </block>
    </view>
    <button class="btn-primary toolbar-btn" size="mini" bindtap="goNew">+ 新建</button>
  </view>

  <view wx:if="{{loading}}" class="empty">加载中...</view>
  <view wx:elif="{{displayPrompts.length === 0}}" class="empty">
    <text>{{prompts.length === 0 ? '还没有任何 Prompt' : '没有匹配的 Prompt'}}</text>
    <button wx:if="{{prompts.length === 0}}" class="btn-primary empty-btn" bindtap="goNew">
      创建第一个
    </button>
  </view>

  <view wx:else>
    <view
      wx:for="{{displayPrompts}}"
      wx:key="id"
      class="card prompt-card"
    >
      <view class="flex-row">
        <checkbox
          wx:if="{{batchMode}}"
          checked="{{item.selected}}"
          data-id="{{item.id}}"
          bindtap="onToggleSelect"
        />
        <view class="flex-1" data-id="{{item.id}}" bindtap="onCardTap">
          <text class="prompt-title">{{item.title}}</text>
          <text class="prompt-content line-clamp-2">{{item.content}}</text>
          <view class="tag-row">
            <text wx:for="{{item.tags}}" wx:for-item="tag" wx:key="*this" class="tag">{{tag}}</text>
          </view>
          <view class="meta text-muted">
            <text>{{item.categoryLabel}}</text>
            <text>使用 {{item.usage_count}} 次</text>
            <text>{{item.dateLabel}}</text>
          </view>
        </view>
        <view wx:if="{{!batchMode}}" class="actions">
          <text class="action-icon" data-id="{{item.id}}" data-content="{{item.content}}" data-title="{{item.title}}" data-usage="{{item.usage_count}}" bindtap="onCopy">复制</text>
          <text class="action-icon" data-id="{{item.id}}" bindtap="goEdit">编辑</text>
          <text class="action-icon danger" data-id="{{item.id}}" bindtap="onDelete">删除</text>
        </view>
      </view>
    </view>
  </view>
</view>
