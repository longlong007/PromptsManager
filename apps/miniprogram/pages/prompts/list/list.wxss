.search-bar {
  display: flex;
  flex-wrap: wrap;
  align-items: center;
  gap: 16rpx;
  margin-bottom: 20rpx;
}

.search-input {
  flex: 1;
  min-width: 200rpx;
}

/* 继承 app.wxss .picker-btn，仅限制宽度 */
.search-bar .picker-btn {
  flex-shrink: 0;
  width: auto;
  max-width: 220rpx;
  font-size: 28rpx;
}

.search-bar .search-btn {
  flex-shrink: 0;
  height: 96rpx !important;
  line-height: 96rpx !important;
  padding: 0 28rpx !important;
  display: inline-flex;
  align-items: center;
  justify-content: center;
}

.toolbar {
  margin-bottom: 20rpx;
}

.toolbar-btn {
  margin-right: 12rpx;
}

.prompt-list {
  padding-bottom: 16rpx;
}

/* 紧凑列表卡片：标题 1 行 + 正文 2 行，其余截断 */
.prompt-card {
  background: #fff;
  border-radius: 20rpx;
  margin-bottom: 20rpx;
  box-shadow: 0 2rpx 12rpx rgba(0, 0, 0, 0.06);
  overflow: hidden;
}

.prompt-card-inner {
  padding: 20rpx 24rpx 12rpx;
  align-items: flex-start;
}

.prompt-checkbox {
  margin-right: 12rpx;
  flex-shrink: 0;
}

.prompt-body {
  min-width: 0;
  overflow: hidden;
}

.prompt-title {
  font-size: 30rpx;
  font-weight: 600;
  color: #111827;
  line-height: 1.35;
}

.prompt-content {
  font-size: 26rpx;
  color: #6b7280;
  line-height: 1.45;
  margin-top: 6rpx;
}

.tag-row {
  margin-top: 8rpx;
  white-space: nowrap;
  overflow: hidden;
}

.tag {
  display: inline-block;
  padding: 4rpx 12rpx;
  background: #f3f4f6;
  color: #4b5563;
  font-size: 20rpx;
  border-radius: 6rpx;
  margin-right: 8rpx;
  vertical-align: middle;
}

.tag-more {
  background: #e5e7eb;
  color: #6b7280;
}

.meta {
  margin-top: 8rpx;
  font-size: 22rpx;
  color: #9ca3af;
  line-height: 1.3;
  white-space: nowrap;
  overflow: hidden;
  text-overflow: ellipsis;
}

.meta-dot {
  margin: 0 6rpx;
}

/* 单行 / 多行省略（须用 view，text 在小程序里 line-clamp 不稳定） */
.ellipsis-1 {
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
  word-break: break-all;
}

.ellipsis-2 {
  overflow: hidden;
  word-break: break-all;
  display: -webkit-box;
  -webkit-box-orient: vertical;
  -webkit-line-clamp: 2;
}

.prompt-actions {
  display: flex;
  border-top: 2rpx solid #f3f4f6;
  padding: 0 8rpx;
}

.action-btn {
  flex: 1;
  text-align: center;
  font-size: 26rpx;
  color: #2563eb;
  padding: 18rpx 0;
}

.action-btn.danger {
  color: #dc2626;
}

.action-btn + .action-btn {
  border-left: 2rpx solid #f3f4f6;
}

.empty-btn {
  margin-top: 32rpx;
}
