.search-bar {
  display: flex;
  flex-wrap: wrap;
  gap: 16rpx;
  margin-bottom: 20rpx;
}

.search-input {
  flex: 1;
  min-width: 200rpx;
}

.picker-btn {
  padding: 20rpx 24rpx;
  background: #fff;
  border: 2rpx solid #d1d5db;
  border-radius: 16rpx;
  font-size: 26rpx;
  max-width: 200rpx;
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
}

.search-btn {
  flex-shrink: 0;
}

.toolbar {
  margin-bottom: 20rpx;
}

.toolbar-btn {
  margin-right: 12rpx;
}

.prompt-card {
  padding: 28rpx;
}

.prompt-title {
  font-size: 32rpx;
  font-weight: 600;
  display: block;
}

.prompt-content {
  font-size: 26rpx;
  color: #6b7280;
  margin-top: 8rpx;
  display: block;
}

.tag-row {
  margin-top: 12rpx;
}

.meta {
  display: flex;
  gap: 24rpx;
  margin-top: 16rpx;
  font-size: 22rpx;
}

.actions {
  display: flex;
  flex-direction: column;
  gap: 12rpx;
  margin-left: 16rpx;
}

.action-icon {
  font-size: 24rpx;
  color: #2563eb;
  padding: 8rpx;
}

.action-icon.danger {
  color: #dc2626;
}

.empty-btn {
  margin-top: 32rpx;
}
