.login-page {
  min-height: 100vh;
  display: flex;
  align-items: center;
  justify-content: center;
  background: linear-gradient(135deg, #eff6ff 0%, #e0e7ff 100%);
  padding: 48rpx 32rpx;
  box-sizing: border-box;
}

.login-card {
  width: 100%;
  max-width: 640rpx;
  background: #fff;
  border-radius: 32rpx;
  padding: 48rpx 40rpx;
  box-shadow: 0 8rpx 40rpx rgba(37, 99, 235, 0.12);
}

.login-header {
  text-align: center;
  margin-bottom: 48rpx;
}

.login-title {
  display: block;
  font-size: 48rpx;
  font-weight: 700;
  color: #111827;
}

.login-subtitle {
  display: block;
  font-size: 28rpx;
  color: #6b7280;
  margin-top: 12rpx;
}

.login-btn {
  width: 100%;
  margin-top: 16rpx;
}

.error-box {
  background: #fef2f2;
  color: #dc2626;
  padding: 20rpx 24rpx;
  border-radius: 16rpx;
  font-size: 26rpx;
  margin-bottom: 16rpx;
}

.toggle-mode {
  text-align: center;
  margin-top: 40rpx;
  font-size: 26rpx;
}

.link {
  color: #2563eb;
  margin-left: 8rpx;
}
