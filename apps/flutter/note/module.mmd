    Repo --> SB

    Detail --> AI[AiService]
    AI --> SB

    List --> Copy[CopyHistoryService]
    Detail --> Copy
    Copy --> Prefs

    Repo --> PromptM[prompt.dart]
    Repo --> CatM[category.dart]
